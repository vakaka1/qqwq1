APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=false
DATABASE_URL=sqlite:///./backend/data/app.db
JWT_SECRET_KEY=change-me-jwt-secret
APP_ENCRYPTION_KEY=change-me-encryption-secret
BOT_BACKEND_TOKEN=change-me-bot-backend-token
BOT_RUNNER_TOKEN=change-me-bot-runner-token
SITE_RUNTIME_TOKEN=replace-with-long-random-site-runtime-token
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# FreeKassa
# FREEKASSA_SHOP_ID=12345
# FREEKASSA_API_KEY=change-me-freekassa-api-key
# FREEKASSA_SECRET_WORD=change-me-freekassa-secret-word
# FREEKASSA_SECRET_WORD_2=change-me-freekassa-secret-word-2
FREEKASSA_SBP_METHOD_ID=44
FREEKASSA_ALLOWED_IPS=168.119.157.136,168.119.60.227,178.154.197.79,51.250.54.238
FREEKASSA_REQUIRE_SOURCE_IP_CHECK=false

# Optional one-time bootstrap for the first admin.
# BOOTSTRAP_ADMIN_ON_STARTUP=true
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-admin-password

# Bot Settings
BOT_SYNC_INTERVAL_SECONDS=30

# Optional for standalone bot запуск вне docker-compose.
# BACKEND_BASE_URL=http://localhost:8000/api/v1
