APP_NAME=Xray Control Center
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=false
DATABASE_URL=sqlite:///./backend/data/app.db
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRE_MINUTES=1440
APP_ENCRYPTION_KEY=change-me-encryption-secret
BOT_BACKEND_TOKEN=change-me-bot-backend-token
BOT_RUNNER_TOKEN=change-me-bot-runner-token
BACKEND_BASE_URL=http://localhost:8000/api/v1
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
TRIAL_DURATION_HOURS=24
SCHEDULER_INTERVAL_MINUTES=5
THREE_XUI_TIMEOUT_SECONDS=20
THREE_XUI_VERIFY_SSL=false
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
PUBLIC_APP_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000/api/v1
